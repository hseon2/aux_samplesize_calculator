# Adobe Analytics API (API로 불러오기 시 필요)
# Adobe Developer Console / Report Suite 정보로 채워주세요. 이 파일을 복사해 .env 로 저장한 뒤 값을 입력하세요.
AA_ORG_ID=your_org_id@AdobeOrg
AA_CLIENT_ID=your_client_id
AA_CLIENT_SECRET=your_client_secret
AA_GLOBAL_COMPANY_ID=your_global_company_id
AA_RSID=your_report_suite_id
AA_SCOPES=openid,AdobeID,additional_info.projectedProductContext
AA_SEGMENT_ID_COUNTRY=your_segment_id_if_needed

# API 서버 포트 (기본 5000, Vite 프록시가 이 포트로 연결)
SERVER_PORT=5000
